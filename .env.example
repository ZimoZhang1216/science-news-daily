LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OpenAI fallback/configuration. Leave blank unless you use OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional polite API metadata.
NCBI_EMAIL=
CROSSREF_MAILTO=
REPORT_PROFILE=chemistry
CHEM_NEWS_MAX_ITEMS=30
CHEM_NEWS_MAX_AI_ITEMS=30

# Email delivery. Use an SMTP authorization code/app password, not your web login password.
# Multiple recipients are supported. Separate addresses with commas or semicolons.
# Chemistry uses CHEM_REPORT_EMAIL_TO first, then REPORT_EMAIL_TO for backward compatibility.
REPORT_EMAIL_TO=2510248@mail.nankai.edu.cn
CHEM_REPORT_EMAIL_TO=
BIO_REPORT_EMAIL_TO=
STAT_REPORT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURITY=ssl
EMAIL_ENABLED=true

# Optional PDF conversion settings. Required only if LibreOffice is not in PATH.
LIBREOFFICE_PATH=
PDF_CONVERT_TIMEOUT=120
